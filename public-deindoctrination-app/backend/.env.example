# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/public-deindoctrination-app

# JWT Secret (generate a strong random string for production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h

# Admin Account (for seeding)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin123!

# Stripe (for payments)
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
# Webhook: https://dashboard.stripe.com/webhooks → add endpoint → /api/checkout/stripe-webhook
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# PayPal (for payments)
# Get keys from: https://developer.paypal.com/dashboard/applications/sandbox
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox
# Change PAYPAL_MODE to 'live' for production

# Email Service (for password reset)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password

# Ad Provider
AD_PROVIDER_KEY=your-ad-provider-key

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
